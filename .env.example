# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Clé service role — NE JAMAIS exposer côté client, utilisée par
# l'assistant IA (recherche RAG, rate-limiting) et le téléchargement des PDF
# d'épreuves — voir lib/supabase/service.ts.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# URL publique du site (utilisée pour les metadata, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Analytics 4 — voir docs/google-analytics.md. Optionnel : sans cet ID,
# aucun script GA n'est chargé (et jamais en dev, ni avant consentement).
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Mini-dashboard admin (stats de téléchargement PDF) — voir
# docs/pdf-downloads.md. Sans cette variable, /admin/login refuse toute
# connexion ; le reste du site fonctionne normalement.
ADMIN_PASSWORD=change-me

# Assistant IA — Q/A sur polytech.sn (voir docs/RAG.md)
# Clé API Groq (console.groq.com). Sans cette variable, /api/chat répond 503 et
# le widget de chat reste désactivé — le reste du site fonctionne normalement.
GROQ_API_KEY=gsk_...
# Optionnel — modèle Groq utilisé pour générer les réponses.
GROQ_MODEL=llama-3.3-70b-versatile
# Optionnel — nombre max de questions autorisées par IP et par 24h.
RAG_MAX_QUESTIONS_PER_IP_PER_DAY=30

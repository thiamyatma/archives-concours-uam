# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Clé service role — NE JAMAIS exposer côté client, utilisée uniquement dans
# les Server Actions (génération des URL signées de téléchargement/aperçu).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# URL publique du site (utilisée pour les metadata, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (resend.com) — notification email à l'admin lors d'une nouvelle
# contribution. Optionnel : si absent, la notification est simplement ignorée.
RESEND_API_KEY=re_...
ADMIN_NOTIFICATION_EMAIL=admin@example.com

# Assistant IA — Q/A sur polytech.sn (voir docs/RAG.md)
# Clé API Groq (console.groq.com). Sans cette variable, /api/chat répond 503 et
# le widget de chat reste désactivé — le reste du site fonctionne normalement.
GROQ_API_KEY=gsk_...
# Optionnel — modèle Groq utilisé pour générer les réponses.
GROQ_MODEL=llama-3.3-70b-versatile
# Optionnel — nombre max de questions autorisées par IP et par 24h.
RAG_MAX_QUESTIONS_PER_IP_PER_DAY=30
